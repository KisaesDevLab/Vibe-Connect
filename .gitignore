# Docker volumes / mail / uploads
infra/docker/data/
infra/docker/mail/
infra/docker/uploads/
# Host-side dev workflows (yarn server:dev, vitest run from apps/server)
# default ATTACHMENT_LOCAL_DIR to ./infra/docker/uploads which resolves
# relative to the workspace's cwd, producing apps/server/infra/docker/uploads.
# Same pattern, different anchor — ignore the whole apps/server/infra tree.
apps/server/infra/

# TLS material — never commit private keys. Certs stay out too so the pair
# moves together; ACME issuance lives in apps/server/src/services/tlsAcme.ts.
infra/docker/tls/*.key
infra/docker/tls/*.crt
infra/docker/tls/*.pem

# Built frontend bundles served by nginx. These drift silently from source
# if committed; the Docker build stage produces them into apps/*/dist/.
infra/docker/static/

# Dev mock-provider outboxes
.outbox/
