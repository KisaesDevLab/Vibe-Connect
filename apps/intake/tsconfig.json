{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": ["vite/client", "node"],
    "allowImportingTsExtensions": false,
    "composite": false
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"]
}
