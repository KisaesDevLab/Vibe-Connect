{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "productName": "Vibe Connect",
  "version": "0.1.0",
  "identifier": "app.vibeconnect.desktop",
  "build": {
    "beforeDevCommand": "yarn --cwd .. dev",
    "devUrl": "http://localhost:5180",
    "beforeBuildCommand": "yarn --cwd .. build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Vibe Connect",
        "width": 1200,
        "height": 780,
        "minWidth": 800,
        "minHeight": 500,
        "decorations": true,
        "resizable": true,
        "fullscreen": false,
        "visible": true
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; connect-src 'self' ipc: http://ipc.localhost https: http: ws: wss:; img-src 'self' data: blob: https: http:; style-src 'self' 'unsafe-inline' https:; script-src 'self' 'wasm-unsafe-eval'",
      "capabilities": ["main-capability"]
    },
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true,
      "menuOnLeftClick": false
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis", "dmg", "app", "appimage", "deb"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "nsis": {
        "installMode": "currentUser"
      },
      "wix": {
        "language": "en-US"
      }
    },
    "macOS": {
      "minimumSystemVersion": "12.0",
      "signingIdentity": null,
      "providerShortName": null,
      "entitlements": null
    },
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0"]
      }
    },
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://kisaesdevlab.github.io/Vibe-Connect/{{target}}/{{arch}}/latest/latest.json",
        "https://kisaesdevlab.github.io/Vibe-Connect/{{target}}/{{arch}}/{{current_version}}/latest.json"
      ],
      "dialog": true,
      "$comment_pubkey": "Generate with `npx tauri signer generate -w apps/desktop/.tauri/signing.key` and paste the public half here. Private half goes into the GitHub Actions secret TAURI_UPDATER_PRIVATE_KEY (and the password into TAURI_UPDATER_PRIVATE_KEY_PASSWORD if one was set). See docs/ops/DESKTOP.md.",
      "pubkey": "REPLACE_WITH_ED25519_PUBLIC_KEY_FROM_UPDATE_SIGNING.md"
    },
    "autostart": { "useLauncher": false },
    "global-shortcut": {},
    "notification": {},
    "store": {}
  }
}
