{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "productName": "Vibe Connect",
  "version": "0.1.0",
  "identifier": "app.vibeconnect.desktop",
  "build": {
    "beforeDevCommand": "yarn --cwd .. dev",
    "devUrl": "http://localhost:5180",
    "beforeBuildCommand": "yarn --cwd .. build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Vibe Connect",
        "width": 1200,
        "height": 780,
        "minWidth": 800,
        "minHeight": 500,
        "decorations": true,
        "resizable": true,
        "fullscreen": false,
        "visible": true
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; connect-src 'self' ipc: http://ipc.localhost https: http: ws: wss:; img-src 'self' data: blob: https: http:; style-src 'self' 'unsafe-inline' https:; script-src 'self' 'wasm-unsafe-eval'",
      "capabilities": ["main-capability"]
    },
    "trayIcon": {
      "iconPath": "icons/icon.ico",
      "menuOnLeftClick": false
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "webviewInstallMode": { "type": "downloadBootstrapper" },
      "nsis": {
        "installMode": "currentUser",
        "installerIcon": "icons/icon.ico",
        "displayLanguageSelector": false
      },
      "wix": {
        "language": "en-US"
      }
    },
    "macOS": {
      "minimumSystemVersion": "12.0",
      "signingIdentity": null,
      "providerShortName": null,
      "entitlements": null
    },
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0"]
      }
    },
    "createUpdaterArtifacts": false
  },
  "plugins": {
    "updater": {
      "$comment": "Updater is OFF until the ed25519 signing keypair is generated. See docs/ops/UPDATE_SIGNING.md. To re-enable: flip active=true, paste the generated public key into pubkey, set dialog=true, and flip bundle.createUpdaterArtifacts back to true.",
      "active": false,
      "endpoints": [
        "https://kisaesdevlab.github.io/Vibe-Connect/{{target}}/{{arch}}/latest/latest.json",
        "https://kisaesdevlab.github.io/Vibe-Connect/{{target}}/{{arch}}/{{current_version}}/latest.json"
      ],
      "dialog": false,
      "pubkey": ""
    },
    "autostart": { "useLauncher": false },
    "global-shortcut": {},
    "notification": {},
    "store": {}
  }
}
