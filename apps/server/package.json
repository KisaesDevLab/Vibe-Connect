{
  "name": "@vibe-connect/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "migrate": "knex --knexfile ./knexfile.cjs migrate:latest",
    "rollback": "knex --knexfile ./knexfile.cjs migrate:rollback",
    "seed": "knex --knexfile ./knexfile.cjs seed:run",
    "reset": "knex --knexfile ./knexfile.cjs migrate:rollback --all && knex --knexfile ./knexfile.cjs migrate:latest && knex --knexfile ./knexfile.cjs seed:run"
  },
  "dependencies": {
    "@vibe-connect/crypto": "0.1.0",
    "@vibe-connect/shared-types": "0.1.0",
    "bcryptjs": "^2.4.3",
    "connect-pg-simple": "^9.0.1",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "email-reply-parser": "^1.7.3",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "express-session": "^1.18.0",
    "helmet": "^7.1.0",
    "knex": "^3.1.0",
    "libsodium-wrappers": "^0.7.13",
    "mailparser": "^3.7.1",
    "multer": "^2.0.0",
    "pg": "^8.12.0",
    "postmark": "^4.0.2",
    "socket.io": "^4.7.5",
    "twilio": "^5.2.0",
    "web-push": "^3.6.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/connect-pg-simple": "^7.0.3",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.0",
    "@types/mailparser": "^3.4.4",
    "@types/multer": "^1.4.11",
    "@types/pg": "^8.11.6",
    "@types/supertest": "^6.0.2",
    "@types/web-push": "^3.6.3",
    "supertest": "^7.0.0",
    "tsx": "^4.16.2",
    "vitest": "^1.6.0"
  }
}
