# ==================================================================
# Vibe Connect — Environment Template
# Copy to `.env` and edit. Any value not set falls back to safe dev defaults.
# ==================================================================

# --- Server ---
NODE_ENV=development
PORT=4000
SITE_URL=http://localhost:5173
PORTAL_URL=http://localhost:5174
API_URL=http://localhost:4000

# --- Database ---
DATABASE_URL=postgres://vibe:vibe@localhost:5435/vibe_connect
# For tests a separate DB is recommended:
TEST_DATABASE_URL=postgres://vibe:vibe@localhost:5435/vibe_connect_test

# --- Session ---
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=change-me-use-a-long-random-value-in-production
SESSION_COOKIE_NAME=vibe.sid
SESSION_SECURE=false
SESSION_SAMESITE=lax

# --- Crypto / firm key ---
# Generated on first-boot admin setup. Leave blank for fresh installs.
FIRM_KEY_PUBLIC=
FIRM_KEY_WRAPPED_PRIVATE=

# --- Attachments ---
ATTACHMENT_DRIVER=local              # local | s3
ATTACHMENT_LOCAL_DIR=./infra/docker/uploads
ATTACHMENT_MAX_BYTES=104857600       # 100 MB
# S3 driver (only used when ATTACHMENT_DRIVER=s3)
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=

# --- Email provider ---
EMAIL_PROVIDER=mock                  # mock | postmark | postfix
EMAIL_FROM=Vibe Connect <noreply@vibeconnect.local>
EMAIL_INBOUND_DOMAIN=connect.vibeconnect.local
POSTMARK_SERVER_TOKEN=
POSTMARK_INBOUND_WEBHOOK_SECRET=
# Dedicated secret for the Postfix pipe's raw-MIME endpoint
# (/bridges/email-inbound-raw). Keep different from the Postmark secret so a
# leak in one channel doesn't open the other. Defaults to
# POSTMARK_INBOUND_WEBHOOK_SECRET if unset (backwards compatible).
POSTFIX_RAW_BRIDGE_SECRET=

# --- SMS provider ---
SMS_PROVIDER=mock                    # mock | textlink | twilio
TEXTLINK_API_KEY=
TEXTLINK_WEBHOOK_SECRET=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_MESSAGING_SERVICE_SID=

# --- Push / VAPID ---
# Generate with: node -e "const w=require('web-push');console.log(w.generateVAPIDKeys())"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@vibeconnect.local

# --- Rate limits ---
RATE_LIMIT_LOGIN_PER_MIN=5
RATE_LIMIT_PORTAL_CODE_PER_10MIN=3
RATE_LIMIT_GLOBAL_PER_MIN=600

# --- Client step-up verification defaults ---
STEPUP_DEFAULT_TIMEOUT_HOURS=24      # 4 | 8 | 24 | 168 | -1 (-1 = never)

# --- Dev outbox (mock providers) ---
OUTBOX_DIR=./.outbox

# --- ClamAV (optional; unset = uploads pass through marked clean) ---
CLAMD_HOST=
CLAMD_PORT=3310

# --- SMTP (used only when EMAIL_PROVIDER=postfix) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false

# --- OpenID Connect (SSO) ---
# Leave all five blank to disable SSO. The login page shows the "Sign in with SSO"
# button only when these are set and issuer discovery succeeds.
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=
OIDC_SCOPES=openid email profile
# Optional: an ID-token claim whose value grants firm-admin on first login.
# E.g. OIDC_ADMIN_CLAIM=groups OIDC_ADMIN_CLAIM_VALUE=vibe-admins
OIDC_ADMIN_CLAIM=
OIDC_ADMIN_CLAIM_VALUE=
