# ==================================================================
# Vibe Connect — Environment Template
# Copy to `.env` and edit. Any value not set falls back to safe dev defaults.
# ==================================================================

# --- Server ---
NODE_ENV=development
PORT=4000
# Daily dev workflow runs the SPAs on Vite dev servers (5173 + 5174); these
# defaults match that. The IMAGE defaults (env.ts) point at port 4000 so an
# operator's `docker compose up` produces working URLs without per-knob tweaks.
SITE_URL=http://localhost:5173
PORTAL_URL=http://localhost:5174
API_URL=http://localhost:4000

# --- Distribution mode ---
# Cross-product distribution shape (see vibe-distribution-plan.md). The same
# image runs in both single-app and multi-app modes — flip the knobs at deploy
# time, no rebuild. Defaults are single-app.
#
#   single-app: BASE_PATH=/        SESSION_COOKIE_PATH=/        TLS_MODE=internal
#   multi-app : BASE_PATH=/connect SESSION_COOKIE_PATH=/connect TLS_MODE=external
#
# BASE_PATH controls the URL prefix the SPAs mount at + the prefix every API
# call hangs off. Cookie path scopes the session cookie so a sibling Vibe app
# (e.g. /mybooks) on the same host can't read it. TLS_MODE flips between the
# in-app Phase-23 ACME ticker (single-appliance, direct internet) and an
# external Caddy / Cloudflare Tunnel terminator.
BASE_PATH=/
SESSION_COOKIE_PATH=/
TLS_MODE=internal
# Migrations run on container start by default. Set to false in the
# appliance overlay so the bootstrap can sequence migrations across
# Vibe apps that share one Postgres (avoiding race-on-startup writes
# to knex_migrations).
MIGRATIONS_AUTO=true
# Compose-only port knobs. Single-app publishes; multi-app clears via
# `!reset []` in docker-compose.grouped.yml.
APP_PUBLISH_PORT=4000
POSTGRES_PUBLISH_PORT=5435
NGINX_PUBLISH_PORT_HTTP=80
NGINX_PUBLISH_PORT_HTTPS=443
NGINX_PUBLISH_PORT_PORTAL=8443
# Surfaced to the SPA via /__vibe-boot.js so the staff UI's About panel can
# show "vibe-connect 1.4.2" without a separate fetch. Set by the release
# pipeline; defaults to 'dev' for local builds.
BUILD_VERSION=dev

# --- CORS ---
# Optional explicit CORS allow-list. Empty = reflect-origin behavior
# (the default appliance shape; SameSite=lax on the session cookie is
# the real write protection). Comma-separated; each entry is either a
# literal origin or `regex:<pattern>` for a RegExp match. Same-origin
# requests (no Origin header) always pass.
# Examples:
#   ALLOWED_ORIGIN=https://connect.firm.com
#   ALLOWED_ORIGIN=https://connect.firm.com,regex:^https://.+\.firm\.com$
ALLOWED_ORIGIN=

# --- Backup criticality ---
# When BACKUP_REQUIRED=true, the server warns after BACKUP_WARN_DAYS of
# silence on /admin/backup-heartbeat and refuses new vault uploads
# after BACKUP_BLOCK_DAYS. Existing data stays readable; only new
# uploads block. Default false for self-managed standalone deploys.
BACKUP_REQUIRED=false
BACKUP_WARN_DAYS=7
BACKUP_BLOCK_DAYS=30
# Bearer token Duplicati (or any backup runner) sends in the
# Authorization header to POST /admin/backup-heartbeat. Required
# (≥32 chars) when BACKUP_REQUIRED=true. Generate:
#   openssl rand -hex 32
BACKUP_HEARTBEAT_TOKEN=

# --- Desktop wrapper download ---
# Where /desktop/ on the staff port redirects. Default is the GitHub
# releases page; appliances on isolated networks may pin to an
# internal mirror. NOT mounted on the portal port (8443).
DESKTOP_DOWNLOAD_URL=https://github.com/KisaesDevLab/Vibe-Connect/releases/latest

# --- tus orphan cleanup ---
# Hours of inactivity before an orphaned tus partial-upload .part file
# under ${ATTACHMENT_LOCAL_DIR}/tus-incoming/ is reclaimed. Default 24
# matches the legacy hardcoded behavior. Raise on appliances where
# upload resumes routinely span days.
TUS_ORPHAN_TTL_HOURS=24

# --- Database ---
DATABASE_URL=postgres://vibe:vibe@localhost:5435/vibe_connect
# For tests a separate DB is recommended:
TEST_DATABASE_URL=postgres://vibe:vibe@localhost:5435/vibe_connect_test

# --- Session ---
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=change-me-use-a-long-random-value-in-production
SESSION_COOKIE_NAME=vibe.sid
SESSION_SECURE=false
SESSION_SAMESITE=lax

# --- Crypto / firm key ---
# Generated on first-boot admin setup. Leave blank for fresh installs.
FIRM_KEY_PUBLIC=
FIRM_KEY_WRAPPED_PRIVATE=

# --- Attachments ---
ATTACHMENT_DRIVER=local              # local | s3
ATTACHMENT_LOCAL_DIR=./infra/docker/uploads
ATTACHMENT_MAX_BYTES=104857600       # 100 MB
# S3 driver (only used when ATTACHMENT_DRIVER=s3)
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=

# --- Email provider ---
# 'none' explicitly disables outbound mail at the env layer. The portal
# /identify response shape stays indistinguishable from the configured
# case so the toggle isn't probe-able; SMS still works for client login.
EMAIL_PROVIDER=mock                  # mock | postmark | postfix | none
EMAIL_FROM=Vibe Connect <noreply@vibeconnect.local>
EMAIL_INBOUND_DOMAIN=connect.vibeconnect.local
POSTMARK_SERVER_TOKEN=
POSTMARK_INBOUND_WEBHOOK_SECRET=
# Dedicated secret for the Postfix pipe's raw-MIME endpoint
# (/bridges/email-inbound-raw). Keep different from the Postmark secret so a
# leak in one channel doesn't open the other. Defaults to
# POSTMARK_INBOUND_WEBHOOK_SECRET if unset (backwards compatible).
POSTFIX_RAW_BRIDGE_SECRET=

# --- SMS provider ---
SMS_PROVIDER=mock                    # mock | textlink | twilio
TEXTLINK_API_KEY=
TEXTLINK_WEBHOOK_SECRET=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_MESSAGING_SERVICE_SID=

# --- Push / VAPID ---
# Generate with: node -e "const w=require('web-push');console.log(w.generateVAPIDKeys())"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@vibeconnect.local

# --- Rate limits ---
RATE_LIMIT_LOGIN_PER_MIN=5
RATE_LIMIT_PORTAL_CODE_PER_10MIN=3
RATE_LIMIT_GLOBAL_PER_MIN=600

# --- Client step-up verification defaults ---
STEPUP_DEFAULT_TIMEOUT_HOURS=24      # 4 | 8 | 24 | 168 | -1 (-1 = never)

# --- Dev outbox (mock providers) ---
OUTBOX_DIR=./.outbox

# --- ClamAV (optional; unset = uploads pass through marked clean) ---
CLAMD_HOST=
CLAMD_PORT=3310

# --- SMTP (used only when EMAIL_PROVIDER=postfix) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false

# --- OpenID Connect (SSO) ---
# Leave all five blank to disable SSO. The login page shows the "Sign in with SSO"
# button only when these are set and issuer discovery succeeds.
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=
OIDC_SCOPES=openid email profile
# Optional: an ID-token claim whose value grants firm-admin on first login.
# E.g. OIDC_ADMIN_CLAIM=groups OIDC_ADMIN_CLAIM_VALUE=vibe-admins
OIDC_ADMIN_CLAIM=
OIDC_ADMIN_CLAIM_VALUE=
